#!/usr/bin/make -f

PREFIX = /usr

clean:
	make -s clean 2>/dev/null || true

build:
	make PREFIX=$(PREFIX)

install: build
	make install PREFIX=$(PREFIX) DESTDIR=$(CURDIR)/debian/wlstatus

binary-arch: install
	mkdir -p $(CURDIR)/debian/wlstatus/DEBIAN
	awk '/^Package:/ {p=1} p' debian/control > $(CURDIR)/debian/wlstatus/DEBIAN/control
	echo "Version: 1.0-2" >> $(CURDIR)/debian/wlstatus/DEBIAN/control
	dpkg-deb --root-owner-group --build $(CURDIR)/debian/wlstatus $(CURDIR)/..

binary: binary-arch

.PHONY: clean build install binary-arch binary
