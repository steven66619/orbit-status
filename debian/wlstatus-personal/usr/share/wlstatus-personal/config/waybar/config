{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces", "custom/text-deco"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "battery", "network", "pulseaudio", "custom/power"],

    "hyprland/workspaces": {
        "format": "    ECHO {name}",
        "on-click": "~/.config/waybar/scripts/keybinds.sh"
    },

    "clock": {
        "format": "    {:%H:%M} ",
        "format-alt": "    [{:%Y-%m-%d}] ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
"cpu": {
        "format": "    SYS.ENG {usage}% ",
        "tooltip": false
    },

    "memory": {
        "format": "    MEM.DRV {}% "
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "    SHLD {capacity}% ",
        "format-charging": "    CHRG {capacity}% ",
        "format-plugged": "    FULL {capacity}% "
    },

    "network": {
        "format-wifi": "    NET.LINK {signalStrength}% ",
        "format-ethernet": "    NET.WIRE ",
        "format-disconnected": "    LINK.LOST "
    },

    "pulseaudio": {
        "format": "    VOL {volume}% ",
        "format-muted": "    MUTED "
    },

    "custom/text-deco": {
        "format": "||     VAULT_OS_v3.0",
        "tooltip": false
    },

    "custom/power": {
        "format": "⏻  SYS.CTRL",
        "tooltip": false,
        "menu": "on-click",
        "menu-file": "/home/ste/.config/waybar/power_menu.xml",
        "menu-actions": {
            "shutdown": "shutdown now",
            "reboot": "reboot",
            "logout": "hyprctl dispatch exit"
        }
    }

   }

