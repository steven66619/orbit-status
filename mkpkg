#!/bin/sh
set -e

usage() {
    cat <<'EOF'
Usage: ./mkpkg [target]

Targets:
  arch       Build and install natively on Arch Linux (default)
  local      Build from source, install to /usr/local
  deb        Build .deb via Docker/Podman (Debian bookworm)
  rpm        Build .rpm via Docker/Podman (Fedora latest)
  deb-native Build .deb using dpkg on Arch
  rpm-native Build .rpm using rpmbuild on Arch
  -h --help  Show this help
EOF
    exit 0
}

TARGET="${1:-arch}"
case "$TARGET" in
    -h|--help) usage ;;
esac

case "$TARGET" in
    arch)
        echo "==> Arch Linux: building and installing natively"
        sudo pacman -S --needed wayland wayland-protocols cairo pango
        make clean 2>/dev/null || true
        make
        sudo make install
        ;;
    local)
        echo "==> Local build: installing to /usr/local"
        make clean 2>/dev/null || true
        make
        sudo make install
        ;;
    deb)
        echo "==> Building .deb via Docker/Podman"
        RUNTIME=$(command -v podman || command -v docker)
        if [ -z "$RUNTIME" ]; then
            echo "ERROR: neither podman nor docker found"
            exit 1
        fi
        $RUNTIME run --rm -v "$PWD:/build:Z" -w /build debian:bookworm \
            sh -c "apt update -qq && apt build-dep -y . && dpkg-buildpackage -us -uc -b"
        ;;
    rpm)
        echo "==> Building .rpm via Docker/Podman"
        RUNTIME=$(command -v podman || command -v docker)
        if [ -z "$RUNTIME" ]; then
            echo "ERROR: neither podman nor docker found"
            exit 1
        fi
        $RUNTIME run --rm -v "$PWD:/build:Z" -w /build fedora:latest \
            sh -c "dnf install -y -q rpm-build && rpmbuild -ba wlstatus.spec"
        ;;
    deb-native)
        echo "==> Building .deb on Arch with dpkg"
        sudo pacman -S --needed dpkg
        dpkg-buildpackage -d -us -uc -b
        echo "==> .deb written to ../wlstatus_*.deb"
        ;;
    rpm-native)
        echo "==> Building .rpm on Arch with rpmbuild"
        sudo pacman -S --needed rpm-tools
        mkdir -p "$HOME/rpmbuild/SOURCES" "$HOME/rpmbuild/SPECS"
        git archive --format=tar.gz -o "$HOME/rpmbuild/SOURCES/wlstatus-1.0.tar.gz" HEAD
        cp wlstatus.spec "$HOME/rpmbuild/SPECS/"
        rpmbuild -ba "$HOME/rpmbuild/SPECS/wlstatus.spec"
        ;;
    *)
        echo "ERROR: unknown target '$TARGET'"
        usage
        ;;
esac
