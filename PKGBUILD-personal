pkgname=wlstatus-personal
pkgver=1.0
pkgrel=1
pkgdesc="wlstatus + personal dotfiles (shell, hyprland, waybar, kitty, fish)"
arch=('x86_64' 'aarch64')
url="https://github.com/steven66619/wlstatus"
license=('MIT')
depends=('wayland' 'cairo' 'pango' 'glib2')
makedepends=('wayland-protocols')
source=("$pkgname-$pkgver.tar.gz::https://github.com/steven66619/wlstatus/archive/refs/heads/personal.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/wlstatus-personal"
  make PREFIX=/usr
}

package() {
  cd "$srcdir/wlstatus-personal"

  make PREFIX=/usr DESTDIR="$pkgdir" install

  install -Dm755 wlstatus-personal-setup "$pkgdir/usr/bin/wlstatus-personal-setup"

  for f in dotfiles/home/*; do
    install -Dm644 "$f" "$pkgdir/usr/share/wlstatus-personal/home/$(basename "$f")"
  done

  for dir in dotfiles/config/*/; do
    name="$(basename "$dir")"
    mkdir -p "$pkgdir/usr/share/wlstatus-personal/config/$name"
    cp -r "$dir"/* "$pkgdir/usr/share/wlstatus-personal/config/$name/"
  done
}
